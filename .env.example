# Environment Configuration
NODE_ENV=test
BASE_URL=https://hub.patter.com
HEADED=false

# ==========================================
# ADMIN CREDENTIALS (Login Simple - SIN OTP)
# ==========================================
# Usuario Admin regular que NO requiere OTP
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SecurePassword123!

# ==========================================
# SUPER ADMIN CREDENTIALS (Login + OTP)
# ==========================================
# Usuario Super Admin que SÍ requiere código OTP de 4 dígitos
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=SuperSecurePassword123!

# Email Service for OTP (Gmail API or IMAP)
EMAIL_SERVICE=gmail
EMAIL_USER=automation@example.com
EMAIL_PASSWORD=app-specific-password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# Gmail API Credentials (Alternative to IMAP)
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Test Configuration
DEFAULT_TIMEOUT=30000
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
RETRY_COUNT=2

# CI/CD Configuration
CI=false
PARALLEL_WORKERS=2

# Reporting
REPORT_PATH=./reports
SCREENSHOT_PATH=./screenshots
